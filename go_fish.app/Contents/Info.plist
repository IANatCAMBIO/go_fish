<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist for the go_fish.app bundle (assembled by `make app`).

  Wrapping the bare binary in a .app bundle is what lets LaunchServices run it
  directly as a Login Item. A bare Unix executable in Login Items is launched
  by Terminal.app (the only "opener" macOS knows for a raw binary), which is
  why running the loose binary at login pops a terminal window. The bundle has
  no such host, so it starts silently.

  LSUIElement makes it a menu-bar "agent": no Dock icon, no app menu, just the
  status item. (The code also sets NSApplicationActivationPolicyAccessory at
  runtime; this key is the static belt-and-suspenders equivalent.)
-->
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>go_fish</string>
    <key>CFBundleIdentifier</key>
    <string>com.local.gofish</string>
    <key>CFBundleName</key>
    <string>go_fish</string>
    <key>CFBundleDisplayName</key>
    <string>go_fish</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleShortVersionString</key>
    <string>2.1.0</string>
    <key>CFBundleVersion</key>
    <string>2.1.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
</dict>
</plist>
